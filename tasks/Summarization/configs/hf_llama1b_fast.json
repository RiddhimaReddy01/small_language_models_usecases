{
  "dataset": {
    "name": "cnn_dailymail",
    "config_name": "3.0.0",
    "split": "test",
    "num_articles": 5,
    "max_article_tokens": 400,
    "seed": 42
  },
  "model": {
    "model_name": "meta-llama/Llama-3.2-1B-Instruct",
    "provider": "huggingface_api",
    "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
    "max_new_tokens": 60,
    "temperature": 0.0,
    "top_p": 1.0,
    "do_sample": false,
    "word_limit": 20
  },
  "prompt": {
    "template": "Summarize the following news article in exactly one complete sentence of 12 to 20 words. Preserve the main event and outcome. Do not output a title, fragment, bullet, or commentary.\n\nArticle:\n{article}\n\nSummary:"
  },
  "output": {
    "output_dir": "Summarization/outputs/hf_llama1b_fast"
  }
}

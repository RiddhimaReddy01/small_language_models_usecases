{
  "benchmark_name": "sroie_ie_gemini_pair_smoke",
  "dataset": {
    "name": "SROIE",
    "clean_path": "Information Extraction/data/processed/sroie_clean.jsonl",
    "noisy_path": "Information Extraction/data/processed/sroie_noisy.jsonl",
    "target_fields": [
      "company",
      "address",
      "date",
      "total"
    ]
  },
  "sampling": {
    "sample_size": 4,
    "sampling_method": "random",
    "random_seed": 42,
    "clean_sample_size": 4,
    "noisy_sample_size": 0
  },
  "models": [
    {
      "name": "gemini-2.5-flash-lite",
      "model_id": "gemini-2.5-flash-lite"
    }
  ],
  "inference": {
    "backend": "gemini",
    "device": "cpu",
    "quantization": "none",
    "double_quantization": false,
    "compute_dtype": "float32",
    "temperature": 0.0,
    "do_sample": false,
    "top_p": 1.0,
    "max_new_tokens": 96,
    "max_input_chars": 2500,
    "torch_threads": 6,
    "low_cpu_mem_usage": true,
    "trust_remote_code": false,
    "timeout_seconds": 120
  },
  "evaluation": {
    "runs_per_model": 1,
    "required_output_format": "json",
    "date_format": "%Y-%m-%d"
  },
  "output_dir": "Information Extraction/outputs_gemini_pair_smoke"
}

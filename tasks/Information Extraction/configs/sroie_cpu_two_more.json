{
  "benchmark_name": "sroie_ie_cpu_two_more_models",
  "dataset": {
    "name": "SROIE",
    "clean_path": "data/processed/sroie_clean.jsonl",
    "noisy_path": "data/processed/sroie_noisy.jsonl",
    "target_fields": [
      "company",
      "address",
      "date",
      "total"
    ]
  },
  "sampling": {
    "sample_size": 10,
    "sampling_method": "random",
    "random_seed": 42,
    "clean_sample_size": 10,
    "noisy_sample_size": 0
  },
  "models": [
    {
      "name": "Qwen2.5-1.5B-Instruct",
      "model_id": "Qwen/Qwen2.5-1.5B-Instruct"
    },
    {
      "name": "SmolLM2-360M-Instruct",
      "model_id": "HuggingFaceTB/SmolLM2-360M-Instruct"
    }
  ],
  "inference": {
    "device": "cpu",
    "quantization": "none",
    "double_quantization": false,
    "compute_dtype": "float32",
    "temperature": 0.0,
    "do_sample": false,
    "top_p": 1.0,
    "max_new_tokens": 64,
    "max_input_chars": 3000,
    "torch_threads": 6,
    "low_cpu_mem_usage": true,
    "trust_remote_code": false
  },
  "evaluation": {
    "runs_per_model": 1,
    "required_output_format": "json",
    "date_format": "%Y-%m-%d"
  },
  "output_dir": "outputs"
}
